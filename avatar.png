<svg width="200" height="220" viewBox="0 0 200 220" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Background glow -->
  <circle cx="100" cy="110" r="90" fill="#07090f"/>
  <circle cx="100" cy="110" r="85" fill="url(#bgGrad)" opacity="0.3"/>

  <!-- Body / suit -->
  <rect x="55" y="140" width="90" height="72" rx="16" fill="#1e1b4b"/>
  <rect x="55" y="140" width="90" height="72" rx="16" fill="url(#suitGrad)" opacity="0.5"/>

  <!-- Shirt collar V -->
  <path d="M85 140 L100 162 L115 140" fill="#312e81" stroke="#4338ca" stroke-width="1.2"/>

  <!-- Tie -->
  <path d="M100 162 L95 188 L100 183 L105 188 Z" fill="#6366f1"/>
  <!-- Tie knot -->
  <rect x="96" y="158" width="8" height="6" rx="2" fill="#818cf8"/>

  <!-- Left arm -->
  <rect x="28" y="146" width="28" height="52" rx="12" fill="#1e1b4b"/>
  <!-- Right arm -->
  <rect x="144" y="146" width="28" height="52" rx="12" fill="#1e1b4b"/>

  <!-- Left hand -->
  <ellipse cx="42" cy="200" rx="13" ry="9" fill="#fbbf24"/>
  <!-- Right hand with tablet -->
  <ellipse cx="158" cy="200" rx="13" ry="9" fill="#fbbf24"/>

  <!-- Tablet in right hand -->
  <rect x="140" y="182" width="32" height="22" rx="4" fill="#0f172a" stroke="#6366f1" stroke-width="1.2"/>
  <rect x="143" y="185" width="26" height="13" rx="2" fill="#1e293b"/>
  <rect x="145" y="187" width="16" height="2" rx="1" fill="#6366f1" opacity="0.9"/>
  <rect x="145" y="191" width="11" height="2" rx="1" fill="#4ade80" opacity="0.9"/>
  <rect x="145" y="195" width="19" height="2" rx="1" fill="#f472b6" opacity="0.8"/>

  <!-- Neck -->
  <rect x="87" y="128" width="26" height="16" rx="6" fill="#fbbf24"/>

  <!-- Head -->
  <ellipse cx="100" cy="96" rx="42" ry="40" fill="#fbbf24"/>

  <!-- Hair base dark -->
  <path d="M60 85 C62 58 76 48 100 47 C124 48 138 60 140 85" fill="#1c1917"/>
  <!-- Hair left side fill -->
  <path d="M60 85 C57 74 63 60 72 55 C65 65 62 76 63 87Z" fill="#1c1917"/>
  <!-- Hair top sweep -->
  <path d="M62 85 C67 70 80 62 96 60 C82 67 70 78 68 90Z" fill="#292524"/>
  <!-- Hair right taper -->
  <path d="M138 85 C138 75 133 64 124 58 C131 67 135 77 136 88Z" fill="#292524"/>
  <!-- Fringe detail -->
  <path d="M88 50 C94 46 108 46 116 52 C108 48 96 48 88 52Z" fill="#292524"/>
  <!-- Side hair piece left -->
  <path d="M60 85 C58 92 60 102 62 108 C60 100 59 90 62 84Z" fill="#1c1917"/>

  <!-- Ears -->
  <ellipse cx="58" cy="98" rx="7" ry="9" fill="#f5c842"/>
  <ellipse cx="142" cy="98" rx="7" ry="9" fill="#f5c842"/>
  <!-- Ear inner -->
  <ellipse cx="58" cy="98" rx="3.5" ry="5.5" fill="#e6aa2a" opacity="0.5"/>
  <ellipse cx="142" cy="98" rx="3.5" ry="5.5" fill="#e6aa2a" opacity="0.5"/>

  <!-- Whites of eyes -->
  <ellipse cx="84" cy="94" rx="9" ry="9.5" fill="white"/>
  <ellipse cx="116" cy="94" rx="9" ry="9.5" fill="white"/>

  <!-- Iris - dark blue smart look -->
  <circle cx="86" cy="95" r="6" fill="#1e3a5f"/>
  <circle cx="118" cy="95" r="6" fill="#1e3a5f"/>

  <!-- Pupil -->
  <circle cx="87" cy="95" r="3.5" fill="#050e1a"/>
  <circle cx="119" cy="95" r="3.5" fill="#050e1a"/>

  <!-- Eye shine -->
  <circle cx="89" cy="92" r="1.4" fill="white" opacity="0.95"/>
  <circle cx="121" cy="92" r="1.4" fill="white" opacity="0.95"/>
  <circle cx="87" cy="97" r="0.6" fill="white" opacity="0.4"/>
  <circle cx="119" cy="97" r="0.6" fill="white" opacity="0.4"/>

  <!-- Eyebrows - sharp angled confident look -->
  <path d="M75 84 C80 80 90 80 95 83" stroke="#1c1917" stroke-width="2.5" fill="none" stroke-linecap="round"/>
  <path d="M105 83 C110 80 120 80 125 84" stroke="#1c1917" stroke-width="2.5" fill="none" stroke-linecap="round"/>

  <!-- Nose -->
  <path d="M97 103 C96 109 97 113 100 114 C103 113 104 109 103 103" stroke="#d4a017" stroke-width="1.4" fill="none" stroke-linecap="round"/>

  <!-- Mouth - confident smirk -->
  <path d="M86 120 C92 126 108 126 114 120" stroke="#b8860b" stroke-width="2" fill="none" stroke-linecap="round"/>
  <!-- Subtle smile dimple -->
  <path d="M86 120 C84 118 85 115 87 116" stroke="#c9971a" stroke-width="1" fill="none" stroke-linecap="round" opacity="0.5"/>

  <!-- Glasses frames - stylish thin indigo -->
  <ellipse cx="84" cy="94" rx="11.5" ry="11" fill="none" stroke="#6366f1" stroke-width="1.5" opacity="0.85"/>
  <ellipse cx="116" cy="94" rx="11.5" ry="11" fill="none" stroke="#6366f1" stroke-width="1.5" opacity="0.85"/>
  <!-- Bridge -->
  <line x1="95.5" y1="94" x2="104.5" y2="94" stroke="#6366f1" stroke-width="1.5" opacity="0.85"/>
  <!-- Arms -->
  <line x1="57" y1="93" x2="72.5" y2="93" stroke="#6366f1" stroke-width="1.5" opacity="0.6"/>
  <line x1="127.5" y1="93" x2="143" y2="93" stroke="#6366f1" stroke-width="1.5" opacity="0.6"/>

  <!-- Floating code particles -->
  <text x="10" y="65" font-size="11" fill="#6366f1" opacity="0.55" font-family="monospace">&lt;/&gt;</text>
  <text x="165" y="58" font-size="10" fill="#4ade80" opacity="0.55" font-family="monospace">{}</text>
  <text x="6" y="155" font-size="9" fill="#f472b6" opacity="0.45" font-family="monospace">AI</text>
  <text x="168" y="148" font-size="9" fill="#fbbf24" opacity="0.45" font-family="monospace">ML</text>
  <text x="12" y="110" font-size="8" fill="#38bdf8" opacity="0.35" font-family="monospace">def</text>
  <text x="162" y="108" font-size="8" fill="#a5b4fc" opacity="0.35" font-family="monospace">aws</text>

  <defs>
    <radialGradient id="bgGrad" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#6366f1"/>
      <stop offset="100%" stop-color="#07090f"/>
    </radialGradient>
    <linearGradient id="suitGrad" x1="55" y1="140" x2="145" y2="212" gradientUnits="userSpaceOnUse">
      <stop offset="0%" stop-color="#818cf8"/>
      <stop offset="100%" stop-color="#4f46e5"/>
    </linearGradient>
  </defs>
</svg>
